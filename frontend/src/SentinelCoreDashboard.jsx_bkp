// ─── Dados simulados (em produção viriam do backend) ─────────────────
const generateLogs = () => {
  const times = ["08:00","08:15","08:30","08:45","09:00","09:15","09:30","09:45","10:00","10:15","10:30","10:45","11:00","11:15","11:30"];
  return times.map((t, i) => ({
    time: t,
    syslog: Math.floor(Math.random() * 80 + 20) * 1e6,
    auth:   Math.floor(Math.random() * 30 + 5)  * 1e6,
    kernel: Math.floor(Math.random() * 15 + 2)  * 1e6,
  }));
};

const generateSources = (C) => [
  { name:"fw-istanbul",      logs: Math.floor(Math.random()*90+10)*1000, color: C.wine },
