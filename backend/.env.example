# ============================================================
#  SentinelCore Backend - Variáveis de Ambiente
#  Copie para .env e preencha os valores
# ============================================================

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Notificações: Email ---
SMTP_HOST=smtp.gmail.com
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=sua-senha-de-app

# --- Notificações: WhatsApp (Evolution API) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-evolution
EVOLUTION_INSTANCE=sentinelcore

# --- Notificações: Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Notificações: Teams ---
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# --- Grafana ---
GRAFANA_PASSWORD=senha-forte-aqui

# --- n8n ---
N8N_PASSWORD=senha-forte-aqui
N8N_ENCRYPTION_KEY=chave-de-32-caracteres-aqui
