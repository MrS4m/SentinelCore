# SentinelCore - Variaveis de ambiente
# Copie para .env e preencha

# IA (opcional para comecar)
ANTHROPIC_API_KEY=

# Banco (ja configurado pelo docker-compose)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@postgres:5432/sentinelcore
REDIS_URL=redis://redis:6379/0

# Ollama (sobe junto com o docker-compose)
OLLAMA_URL=http://ollama:11434

# Notificacoes (opcional)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Grafana
GRAFANA_PASSWORD=sentinel123

# n8n
N8N_PASSWORD=sentinel123
N8N_ENCRYPTION_KEY=mude-esta-chave-em-producao-32ch

# App
DEBUG=false
SECRET_KEY=mude-esta-chave-em-producao-aqui
